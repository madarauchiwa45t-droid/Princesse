{
  "expo": {
    "name": "Megan",
    "slug": "megan",
    "version": "2.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "orientation": "portrait",
    "sdkVersion": "51.0.0",
    "platforms": ["ios", "android", "web"],
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#091540"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.megan.player",
      "versionCode": 3,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "buildToolsVersion": "35.0.0",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#091540"
      },
      "allowBackup": false,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "content", "mimeType": "audio/*" },
            { "scheme": "content", "mimeType": "video/*" },
            { "scheme": "file", "mimeType": "audio/*" },
            { "scheme": "file", "mimeType": "video/*" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.megan.player",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": false
      },
      "usesNonExemptEncryption": false
    },
    "web": {
      "favicon": "./assets/logo.png",
      "name": "Megan",
      "shortName": "Megan",
      "description": "Lecteur Futuriste Vidéos & Musiques v2",
      "themeColor": "#091540",
      "backgroundColor": "#091540",
      "display": "standalone",
      "orientation": "portrait",
      "scope": "/",
      "startUrl": "/",
      "bundler": "webpack"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Accès à vos médias pour lire musiques et vidéos.",
          "savePhotosPermission": "Autoriser Megan à sauvegarder des médias.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Choisissez une image de fond personnalisée."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EXPO_PROJECT_ID"
      }
    }
  }
}
